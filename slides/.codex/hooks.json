{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "yaah hook SessionStart",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "yaah hook Stop",
            "timeout": 10
          }
        ]
      }
    ]
  }
}